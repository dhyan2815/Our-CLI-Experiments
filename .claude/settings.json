{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude agent run session-memory-updater --prompt \"$ARGUMENTS\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(src/**)",
      "Write(test/**)",
      "Write(.claude/**)",
      "Bash(make:*)",
      "Bash(npm run:*)",
      "Bash(npm test *)",
      "Bash(npm run build *)"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ]
  }
}